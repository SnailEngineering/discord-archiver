# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Credentials must match discord-jarvis's MONGO_ROOT_USER / MONGO_ROOT_PASSWORD.
# In Docker (Portainer), "mongodb" resolves via the shared discord-network.
# For local dev, use localhost:27017 instead.
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password
# docker-compose.yml builds this automatically from the two vars above.
# Override only if you need a custom URI:
# MONGODB_URI=mongodb://admin:password@mongodb:27017/discord-jarvis?authSource=admin

# ── Backfill mode ─────────────────────────────────────────────────────────────
# Controls how far back to archive. Leave unset for incremental sync.
#
#   yesterday   — past 24 hours
#   last_week   — past 7 days
#   last_month  — past 30 days
#   last_year   — past 365 days
#   all         — everything since 2015-01-01 (full history)
#   custom      — use BACKFILL_START_DATE / BACKFILL_END_DATE below
#
BACKFILL_MODE=

# Only required when BACKFILL_MODE=custom (ISO 8601)
BACKFILL_START_DATE=
BACKFILL_END_DATE=
